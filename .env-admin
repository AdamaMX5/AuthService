# Database - Use admin user
MONGODB_URI=mongodb://admin:geheim123@mongodb:27017/authdb?authSource=admin

# JWT algorithm
ALGORITHM=RS256

# JWT key locations
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# CORS
CORS_ORIGINS=*

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
