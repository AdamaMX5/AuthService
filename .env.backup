# Database
MONGODB_URI=mongodb://admin:geheim123@mongodb:27017/authdb?authSource=admin

# JWT algorithm
ALGORITHM=RS256

# JWT key locations
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# CORS - ALLOW EVERYTHING including localhost
CORS_ORIGINS=*,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,null
CORS_METHODS=*
CORS_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
