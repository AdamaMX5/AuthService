# Database
DATABASE_URL=sqlite+aiosqlite:///./auth.db

# JWT algorithm
# Recommended: RS256 with key files
ALGORITHM=RS256

# JWT key locations
JWT_PRIVATE_KEY_PATH=keys/jwt_private.asc
JWT_PUBLIC_KEY_PATH=keys/jwt_public.asc

# If your private key is encrypted, set passphrase here
JWT_PRIVATE_KEY_PASSPHRASE=change-me

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Optional only for HS256 setups. If ALGORITHM=RS256, this can stay empty/removed.
# SECRET_KEY=replace-only-if-using-hs256
