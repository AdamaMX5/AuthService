# Database
MONGODB_URI=mongodb://<user>:<password>@<host>:27017/authdb

# JWT algorithm
# Recommended: RS256 with key files
ALGORITHM=RS256

# JWT key locations
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# If your private key is encrypted, set passphrase here.
# Keep empty for password-free/unencrypted auto-generated private keys.
JWT_PRIVATE_KEY_PASSPHRASE=

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Optional only for HS256 setups. If ALGORITHM=RS256, this can stay empty/removed.
# SECRET_KEY=replace-only-if-using-hs256

# Internal service-to-service auth (/internal/* endpoints).
# One key per calling service, never a shared master key: if a key leaks, only
# that service's access needs to be revoked. Rotate by changing the value and
# redeploying.
# INTERNAL_API_KEY_TICKET_SERVICE=replace-with-a-long-random-secret
# INTERNAL_API_KEY_MARKET_SERVICE=replace-with-a-long-random-secret
